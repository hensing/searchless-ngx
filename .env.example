# Paperless-ngx Configuration
PAPERLESS_URL=http://your-paperless-url:8000
PAPERLESS_TOKEN=your_api_token_here

# Google Gemini API (used for Vector Embeddings and Chat UI)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Limit initial sync to the X newest documents (for testing/debug)
# BULK_SYNC_LIMIT=100

# Optional: Local Ollama Configuration (if not using Gemini for Chat)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
