# Paperless-ngx Configuration
PAPERLESS_URL=http://your-paperless-url:8000
PAPERLESS_TOKEN=your_api_token_here

# LLM provider: "mistral", "google", "openai" or "ollama".
# Umbrella default for both axes below. Each axis falls back to this when unset.
LLM_PROVIDER=mistral

# Best-of-breed (optional): split embeddings and chat across providers.
#   EMBEDDING_PROVIDER → vector-store embeddings (drives retrieval quality)
#   CHAT_PROVIDER      → internal fuzzy-match LLM call
# Example: Google's stronger embeddings + Mistral (EU) for chat — needs BOTH keys.
# EMBEDDING_PROVIDER=google
# CHAT_PROVIDER=mistral
#
# NOTE: changing the EMBEDDING provider requires rebuilding the vector DB —
#       wipe the 'chroma_data' volume and run a full re-sync (embeddings are not
#       comparable across models/dimensions).

# API keys — required only for the provider(s) actually in use. (ollama needs none.)
MISTRAL_API_KEY=your_mistral_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1   # only to point "openai" at another host

# Ollama (local models, no API key). Inside Docker, reach the host via host.docker.internal;
# run `OLLAMA_HOST=0.0.0.0 ollama serve` on the host so the container can connect.
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# --- Fully local example: Qwen3 embeddings + Mistral Small 24B, both on Ollama ---
# Pull first:  ollama pull qwen3-embedding:0.6b   &&   ollama pull mistral-small:24b
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# EMBEDDING_MODEL=qwen3-embedding:0.6b   # 1024-dim (recommended). Alt: :4b (2560), :8b (4096)
# CHAT_MODEL=mistral-small:24b
# Always pin an explicit tag — bare "qwen3-embedding" / ":latest" = 8B (4096-dim).

# Optional: override the default models per axis (provider defaults apply when unset)
# EMBEDDING_MODEL=mistral-embed
# CHAT_MODEL=mistral-small-latest

# Optional: Log level (DEBUG, INFO, WARNING, ERROR). Default: INFO
# At DEBUG level, httpx request logs are also shown.
# LOG_LEVEL=INFO

# Optional: Limit initial sync to the X newest documents (for testing/debug)
# BULK_SYNC_LIMIT=100

# Optional: Maximum chunks per document (100 chunks ≈ 25 DIN-A4 pages)
# MAX_CHUNKS_PER_DOC=100

# Optional: Local Ollama Configuration (if not using Gemini for Chat)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
SYNC_INTERVAL_MINUTES=15
